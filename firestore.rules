rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public read access for event/page data; no client writes
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    match /pages/{pageId} {
      allow read: if true;
      allow write: if false;
    }

    // Admin-only collections - NO CLIENT ACCESS EVER
    match /admin/{document=**} {
      allow read, write: if false;
    }

    // Logs collection - server-side only
    match /logs/{document=**} {
      allow read, write: if false;
    }

    // User profile data — users may only update their own liked-events list
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedItemIds', 'updatedAt']);
    }

    // Account profile data (role and organizer metadata)
    match /userProfiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.organizerNames == resource.data.organizerNames;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}