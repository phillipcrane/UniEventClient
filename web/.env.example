# Canonical source of truth for all env vars is UniEventServer/.env.example.
# Mirror the VITE_* block from there into this file for local dev.
#
# Leave VITE_BACKEND_URL empty for same-origin deployments (nginx proxy_pass / Vite proxy).
# Set to http://localhost:8080 when running the Spring Boot server locally.
VITE_BACKEND_URL=
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_GCP_PROJECT_ID=your-project-id
# Password that gates organizer self-registration on the signup page.
VITE_ORGANIZER_SIGNUP_PASSWORD=