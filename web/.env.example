# Leave empty only for same-origin deployments where /api and /media are routed
# to the backend (for example via a Vite dev proxy, nginx proxy_pass, or an ingress).
# Otherwise, set this to the backend base URL explicitly.
VITE_BACKEND_URL=
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_GCP_PROJECT_ID=your-project-id